---
import { ViewTransitions } from 'astro:transitions';
---

<!doctype html>
<html lang="en" class="antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Prism The Gift Fund - Client Portal Login" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>Prism The Gift Fund - Sign In</title>
    <ViewTransitions />
    <style>
      html {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
      }
    </style>
  </head>
  <body class="bg-navy-600 min-h-screen flex flex-col" style="background-image: radial-gradient(circle at 25% 25%, rgba(197,165,90,0.06) 0%, transparent 50%), radial-gradient(circle at 75% 75%, rgba(197,165,90,0.04) 0%, transparent 50%)">
    <div class="flex-1 flex items-center justify-center px-4 py-12">
      <div class="w-full max-w-md">
        <!-- Logo / Brand -->
        <div class="text-center mb-10">
          <div class="inline-flex items-center justify-center w-16 h-16 sm:w-20 sm:h-20 rounded-full bg-navy-700 border-2 border-gold-500 mb-6">
            <span class="font-serif text-3xl font-bold text-gold-400">P</span>
          </div>
          <h1 class="font-serif text-2xl sm:text-3xl font-bold text-white tracking-wide mb-1">PRISM</h1>
          <p class="text-gold-400 text-sm font-medium tracking-widest uppercase">The Gift Fund</p>
        </div>

        <!-- Login Card -->
        <div class="bg-white rounded-xl shadow-2xl p-6 sm:p-8">
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-slate-800">Client Portal</h2>
            <p class="text-sm text-slate-400 mt-1">Sign in to access your fund dashboard</p>
          </div>

          <!-- Portal Selector -->
          <div class="mb-6">
            <p class="text-xs text-slate-400 text-center uppercase tracking-wider font-medium mb-4">Select your portal</p>
            <div class="grid grid-cols-3 gap-3">
              <button
                type="button"
                data-portal="donor"
                class="portal-btn flex flex-col items-center gap-2 p-3 rounded-lg ring-2 ring-navy-600 bg-navy-50/50 text-navy-700 transition-all shadow-sm text-center cursor-pointer"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                </svg>
                <span class="text-xs font-medium">Donor Portal</span>
              </button>
              <button
                type="button"
                data-portal="admin"
                class="portal-btn flex flex-col items-center gap-2 p-3 rounded-lg border border-slate-200 text-slate-600 hover:border-navy-300 hover:text-navy-600 hover:bg-navy-50 transition-all text-center cursor-pointer"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="text-xs font-medium">Administration</span>
              </button>
              <button
                type="button"
                data-portal="grantee"
                class="portal-btn flex flex-col items-center gap-2 p-3 rounded-lg border border-slate-200 text-slate-600 hover:border-navy-300 hover:text-navy-600 hover:bg-navy-50 transition-all text-center cursor-pointer"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
                </svg>
                <span class="text-xs font-medium">Grantee Portal</span>
              </button>
            </div>
          </div>

          <form id="login-form" class="space-y-5">
            <div>
              <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">
                Email Address
              </label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="you@example.com"
                class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-navy-600 focus:border-transparent transition-shadow"
              />
            </div>

            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label for="password" class="block text-sm font-medium text-slate-700">
                  Password
                </label>
                <a href="#" class="text-xs text-navy-600 hover:text-navy-700 font-medium transition-colors">
                  Forgot password?
                </a>
              </div>
              <input
                type="password"
                id="password"
                name="password"
                placeholder="Enter your password"
                class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-navy-600 focus:border-transparent transition-shadow"
              />
            </div>

            <div class="flex items-center">
              <input
                type="checkbox"
                id="remember"
                class="w-4 h-4 rounded border-slate-300 text-navy-600 focus:ring-navy-600"
              />
              <label for="remember" class="ml-2 text-sm text-slate-500">Remember this device</label>
            </div>

            <button
              type="submit"
              id="sign-in-btn"
              class="w-full inline-flex items-center justify-center px-4 py-2.5 rounded-lg bg-navy-600 text-white text-sm font-medium hover:bg-navy-700 transition-colors shadow-sm cursor-pointer"
            >
              Sign In
            </button>
          </form>

          <div class="mt-4 pt-4 border-t border-slate-100">
            <p class="text-xs text-slate-400 text-center">
              Demo environment — not for use with real client data.
            </p>
          </div>
        </div>

        <!-- Security badges -->
        <div class="mt-6 flex flex-wrap items-center justify-center gap-4 sm:gap-6 text-xs text-navy-200">
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            Secure Login
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            Registered Charity
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            UK Based
          </span>
        </div>
      </div>
    </div>

    <script>
      const BASE = '';
      const routes: Record<string, string> = {
        donor: `${BASE}dashboard`,
        admin: `${BASE}admin`,
        grantee: `${BASE}grantee`,
      };

      let selectedPortal = 'donor';

      const selectedClasses = ['ring-2', 'ring-navy-600', 'bg-navy-50/50', 'text-navy-700', 'border-transparent'];
      const unselectedClasses = ['border', 'border-slate-200', 'text-slate-600'];

      function selectPortal(portal: string) {
        selectedPortal = portal;
        document.querySelectorAll<HTMLButtonElement>('.portal-btn').forEach((btn) => {
          const isSelected = btn.dataset.portal === portal;
          selectedClasses.forEach((c) => btn.classList.toggle(c, isSelected));
          unselectedClasses.forEach((c) => btn.classList.toggle(c, !isSelected));
        });
      }

      document.querySelectorAll<HTMLButtonElement>('.portal-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          selectPortal(btn.dataset.portal!);
        });
      });

      document.getElementById('login-form')?.addEventListener('submit', (e) => {
        e.preventDefault();
        window.location.href = routes[selectedPortal];
      });
    </script>

    <!-- Footer -->
    <footer class="py-6">
      <div class="flex flex-col items-center gap-2">
        <p class="text-navy-300 text-xs">
          &copy; 2026 Prism The Gift Fund. Registered Charity No. 1099682.
        </p>
        <div class="flex items-center gap-3 text-xs text-navy-400">
          <span>Powered by Synaptic</span>
          <span class="text-navy-500">|</span>
          <span>Privacy Policy (Coming Soon)</span>
          <span>Terms of Use (Coming Soon)</span>
        </div>
      </div>
    </footer>
  </body>
</html>
