---
import AdminLayout from '../../layouts/AdminLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { loadAdminData } from '../../lib/data-loader';
import { formatCurrencyFull } from '../../data/admin';
import ROIByChannelChart from '../../components/admin/ROIByChannelChart';
import ActivitiesTable from '../../components/admin/ActivitiesTable';
const BASE = import.meta.env.BASE_URL;

const { bdActivities: activities } = await loadAdminData();
const completed = activities.filter(a => a.status === 'Completed');
const planned = activities.filter(a => a.status === 'Planned');
const totalCost = completed.reduce((s, a) => s + a.cost, 0);
const totalProspects = completed.reduce((s, a) => s + a.prospectsGenerated, 0);
const costPerProspect = totalProspects > 0 ? Math.round(totalCost / totalProspects) : 0;

// Best type
const typePerformance: Record<string, { cost: number; prospects: number }> = {};
for (const a of completed) {
  if (!typePerformance[a.type]) typePerformance[a.type] = { cost: 0, prospects: 0 };
  typePerformance[a.type].cost += a.cost;
  typePerformance[a.type].prospects += a.prospectsGenerated;
}
const bestType = Object.entries(typePerformance)
  .filter(([_, v]) => v.prospects > 0)
  .sort((a, b) => (a[1].cost / a[1].prospects) - (b[1].cost / b[1].prospects))[0];
---

<AdminLayout title="Activities - Prism Admin" activePage="activities">
  <Breadcrumbs items={[{label:"Admin", href:`${BASE}admin`}, {label:"Activities"}]} />
  <div class="mb-6 animate-fade-up">
    <h2 class="text-2xl font-bold text-slate-900">BD Activities</h2>
    <p class="text-sm text-slate-500 mt-1">Business development events and campaigns</p>
  </div>

  <!-- Summary -->
  <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 animate-fade-up">
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Completed</p>
      <p class="text-xl font-bold text-slate-900 mt-1">{completed.length}</p>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 animate-fade-up-1">
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Planned</p>
      <p class="text-xl font-bold text-blue-600 mt-1">{planned.length}</p>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 animate-fade-up-2">
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Total Spend</p>
      <p class="text-xl font-bold text-slate-900 mt-1">{formatCurrencyFull(totalCost)}</p>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 animate-fade-up-3">
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Cost / Prospect</p>
      <p class="text-xl font-bold text-slate-900 mt-1">{formatCurrencyFull(costPerProspect)}</p>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 animate-fade-up-4">
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Best Channel</p>
      <p class="text-lg font-bold text-navy-600 mt-1">{bestType ? bestType[0] : '-'}</p>
    </div>
  </div>

  <!-- ROI Chart -->
  <div class="mb-6 animate-fade-up-4">
    <ROIByChannelChart client:visible activities={activities} />
  </div>

  <!-- Activities Table -->
  <div class="animate-fade-up-4">
    <ActivitiesTable client:load activities={JSON.parse(JSON.stringify(activities))} />
  </div>
</AdminLayout>
