---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  clientName?: string;
  clientId?: string;
}

const { title, clientName, clientId } = Astro.props;
---

<!doctype html>
<html lang="en" class="antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Prism The Gift Fund - Client Portal" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ViewTransitions />
    <style>
      html {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
      }
    </style>
  </head>
  <body class="bg-slate-50 min-h-screen">
    <nav class="bg-navy-600 shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex items-center space-x-8">
            <a href={import.meta.env.BASE_URL} class="flex items-center space-x-3">
              <span class="font-serif text-2xl font-bold text-white tracking-wide">PRISM</span>
              <span class="text-gold-400 text-xs font-medium tracking-widest uppercase hidden sm:inline">The Gift Fund</span>
            </a>
            {clientName && (
              <div class="hidden md:flex items-center space-x-2">
                <div class="w-px h-6 bg-navy-400"></div>
                <span class="text-navy-200 text-sm font-medium ml-2">{clientName}</span>
              </div>
            )}
          </div>
          <div class="flex items-center space-x-4">
            {clientId && (
              <a
                href={import.meta.env.BASE_URL}
                class="text-navy-200 hover:text-white text-sm font-medium transition-colors"
              >
                Switch Account
              </a>
            )}
            <button class="flex items-center space-x-2 text-navy-200 hover:text-white text-sm font-medium transition-colors">
              <svg class="w-4 h-4" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
              <span>Logout</span>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>

    <footer class="border-t border-slate-200 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex flex-col sm:flex-row justify-between items-center space-y-2 sm:space-y-0">
          <p class="text-slate-400 text-xs">
            &copy; 2026 Prism The Gift Fund. Registered Charity No. 1099682. All rights reserved.
          </p>
          <div class="flex items-center space-x-4 text-xs text-slate-400">
            <span>Powered by Synaptic</span>
            <span class="text-slate-300">|</span>
            <a href="#" class="hover:text-navy-600 transition-colors">Privacy Policy</a>
            <a href="#" class="hover:text-navy-600 transition-colors">Terms of Use</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
