---
import Layout from '../../layouts/Layout.astro';
import { getCharities, getAllGrants, getReportsDue, formatCurrency } from '../../data/grantees';

const charities = getCharities();
const allGrants = getAllGrants();
const reportsDue = getReportsDue();
const base = import.meta.env.BASE_URL;

const totalGrantsReceived = allGrants.filter(g => g.stage === 'Paid').length;
const totalAmountReceived = allGrants.filter(g => g.stage === 'Paid').reduce((s, g) => s + g.amount, 0);
const activeGrantCount = allGrants.filter(g => !['Paid', 'Declined'].includes(g.stage)).length;
const activeCharities = charities.filter(c => c.activeGrants > 0).length;
---

<Layout title="Grantee Portal - Prism The Gift Fund">
  <div class="max-w-6xl mx-auto py-12 px-4">
    <div class="text-center mb-10 animate-fade-up">
      <h1 class="text-3xl font-bold text-slate-900 mb-2">Grantee Portal</h1>
      <p class="text-slate-500 text-base">View grant status, reports, documents, and payments</p>
    </div>

    <!-- Aggregate Summary Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 animate-fade-up">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">Grants Paid</span>
          <div class="w-8 h-8 rounded-lg bg-green-50 flex items-center justify-center">
            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        </div>
        <p class="text-2xl font-bold text-slate-900">{totalGrantsReceived}</p>
        <p class="text-xs text-slate-500 mt-1">{formatCurrency(totalAmountReceived)} total</p>
      </div>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 animate-fade-up-1">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">Active Grants</span>
          <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center">
            <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
            </svg>
          </div>
        </div>
        <p class="text-2xl font-bold text-slate-900">{activeGrantCount}</p>
        <p class="text-xs text-slate-500 mt-1">across {activeCharities} charities</p>
      </div>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 animate-fade-up-2">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">Reports Due</span>
          <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center">
            <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        </div>
        <p class:list={['text-2xl font-bold', reportsDue.length > 0 ? 'text-amber-600' : 'text-slate-900']}>{reportsDue.length}</p>
        <p class="text-xs text-slate-500 mt-1">{reportsDue.filter(r => r.reportStatus === 'Overdue').length > 0 ? `${reportsDue.filter(r => r.reportStatus === 'Overdue').length} overdue` : 'All on track'}</p>
      </div>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 animate-fade-up-3">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">Charities</span>
          <div class="w-8 h-8 rounded-lg bg-purple-50 flex items-center justify-center">
            <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
        </div>
        <p class="text-2xl font-bold text-slate-900">{charities.length}</p>
        <p class="text-xs text-slate-500 mt-1">registered grantees</p>
      </div>
    </div>

    <!-- Charity Selector -->
    <div class="mb-6 animate-fade-up-4">
      <h2 class="text-lg font-semibold text-slate-900 mb-1">Select Your Charity</h2>
      <p class="text-sm text-slate-500">Choose a charity to view its grant dashboard</p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {charities.map((charity, idx) => (
        <a
          href={`${base}grantee/dashboard?charity=${charity.id}`}
          class="group bg-white rounded-xl border border-slate-200 shadow-sm hover:shadow-md transition-all duration-200 block p-5 animate-fade-up-4"
        >
          <div class="mb-3">
            <h3 class="text-base font-bold text-slate-900 group-hover:text-emerald-700 transition-colors">
              {charity.charityName}
            </h3>
            <p class="text-xs text-slate-400 mt-0.5">Charity No. {charity.charityNumber}</p>
          </div>

          <div class="mb-3">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">
              {charity.sector}
            </span>
          </div>

          <div class="flex items-center justify-between pt-3 border-t border-slate-100">
            <div>
              <p class="text-xs text-slate-400 uppercase tracking-wider mb-0.5">Active Grants</p>
              <p class="text-sm font-semibold text-slate-800">{charity.activeGrants}</p>
            </div>
            <div class="text-right">
              <p class="text-xs text-slate-400 uppercase tracking-wider mb-0.5">Total Received</p>
              <p class="text-sm font-semibold text-slate-800">{formatCurrency(charity.totalReceived)}</p>
            </div>
          </div>

          <div class="mt-3 pt-3 border-t border-slate-100 flex items-center justify-between">
            <span class="text-sm font-medium text-emerald-600 group-hover:text-emerald-700 transition-colors">
              View Dashboard &rarr;
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
