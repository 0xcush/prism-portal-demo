---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { loadAllDonorClients } from '../../lib/donor-data-loader';
import type { ClientData, Grant } from '../../data/clients';
import GrantDetail from '../../components/GrantDetail';

const { id } = Astro.params;

// Find the grant and its parent client from all donor clients
const allClients = await loadAllDonorClients();
let grant: Grant | undefined;
let client: ClientData | undefined;

for (const c of allClients) {
  const g = c.grants.find((g) => g.id === id);
  if (g) {
    grant = g;
    client = c;
    break;
  }
}

if (!grant || !client) {
  return Astro.redirect(import.meta.env.BASE_URL);
}
---

<DashboardLayout
  title={`${grant.charity} - Grant Detail`}
  clientId={client.id}
  clientName={client.name}
  activePage="grants"
  relationshipManager={client.relationshipManager}
>
  <GrantDetail
    client:load
    grant={grant}
    clientId={client.id}
    baseUrl={import.meta.env.BASE_URL}
  />
</DashboardLayout>
