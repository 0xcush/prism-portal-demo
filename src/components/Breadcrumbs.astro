---
interface BreadcrumbItem {
  label: string;
  href?: string;
}
interface Props {
  items: BreadcrumbItem[];
}
const { items } = Astro.props;
---
<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex items-center gap-1.5 text-sm">
    {items.map((item, idx) => (
      <li class="flex items-center gap-1.5">
        {idx > 0 && (
          <svg class="w-3.5 h-3.5 text-slate-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        )}
        {item.href ? (
          <a href={item.href} class="text-slate-400 hover:text-navy-600 transition-colors">{item.label}</a>
        ) : (
          <span class="text-slate-700 font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
